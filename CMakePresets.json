{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "linux",
      "inherits": "base",
      "displayName": "Linux (Release)",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "windows",
      "inherits": "base",
      "displayName": "Windows (MSVC, Release)",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "windows-static",
      "inherits": "windows",
      "displayName": "Windows (MSVC, static single-exe)",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QT_STATIC_DIR}",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
      }
    },
    {
      "name": "macos",
      "inherits": "base",
      "displayName": "macOS (universal, Release)",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_OSX_ARCHITECTURES": "arm64;x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    }
  ],
  "buildPresets": [
    { "name": "linux",   "configurePreset": "linux" },
    { "name": "windows", "configurePreset": "windows" },
    { "name": "windows-static", "configurePreset": "windows-static" },
    { "name": "macos",   "configurePreset": "macos" }
  ]
}
